<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:layout_marginTop="20dp">

    <LinearLayout
        android:id="@+id/screenContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/week_days"
                android:textColor="#1F2A24"
                android:textSize="22sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/settingsButton"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:background="@null"
                android:contentDescription="@string/settings"
                android:padding="4dp"
                android:src="@drawable/settings" />

        </LinearLayout>

        <RadioGroup
            android:id="@+id/dayGroup"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="14dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/rounted_rectangle">

            <RadioButton
                android:id="@+id/monday"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="0dp"
                android:layout_weight="1"
                android:background="@drawable/day_week_circle_selector"
                android:button="@null"
                android:checked="true"
                android:gravity="center"
                android:text="Пн"
                android:textColor="@color/black"
                android:textSize="14sp" />

            <RadioButton
                android:id="@+id/tuesday"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="0dp"
                android:layout_weight="1"
                android:background="@drawable/day_week_circle_selector"
                android:button="@null"
                android:gravity="center"
                android:text="Вт"
                android:textColor="@color/black"
                android:textSize="14sp" />

            <RadioButton
                android:id="@+id/wednesday"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="0dp"
                android:layout_weight="1"
                android:background="@drawable/day_week_circle_selector"
                android:button="@null"
                android:gravity="center"
                android:text="Ср"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:textStyle="" />

            <RadioButton
                android:id="@+id/thursday"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="0dp"
                android:layout_weight="1"
                android:background="@drawable/day_week_circle_selector"
                android:button="@null"
                android:gravity="center"
                android:text="Чт"
                android:textColor="@color/black"
                android:textSize="14sp" />

            <RadioButton
                android:id="@+id/friday"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="0dp"
                android:layout_weight="1"
                android:background="@drawable/day_week_circle_selector"
                android:button="@null"
                android:gravity="center"
                android:text="Пт"
                android:textColor="@color/black"
                android:textSize="14sp" />

            <RadioButton
                android:id="@+id/saturday"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="0dp"
                android:layout_weight="1"
                android:background="@drawable/day_week_circle_selector"
                android:button="@null"
                android:gravity="center"
                android:text="Сб"
                android:textColor="@color/black"
                android:textSize="14sp" />

            <RadioButton
                android:id="@+id/sunday"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="0dp"
                android:layout_weight="1"
                android:background="@drawable/day_week_circle_selector"
                android:button="@null"
                android:gravity="center"
                android:text="Вс"
                android:textColor="@color/black"
                android:textSize="14sp" />
        </RadioGroup>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/selectedDayLabel"
                android:layout_width="329dp"
                android:layout_height="wrap_content"
                android:text="@string/today_menu"
                android:textColor="#2D3833"
                android:textSize="28sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/trashButton"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:background="@null"
                android:src="@drawable/trash"
                android:contentDescription="@string/delete"/>

        </LinearLayout>


        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_weight="1"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical">

                    <Button
                        android:id="@+id/breakfastButton"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/button_background"
                        android:backgroundTint="@null"
                        android:drawableEnd="@drawable/strelka"
                        android:gravity="center_vertical|start"
                        android:paddingStart="14dp"
                        android:paddingEnd="12dp"
                        android:text="@string/meal_breakfast"
                        android:textAllCaps="false"
                        android:textColor="#258B4E"
                        android:textSize="24sp"
                        app:backgroundTint="@null" />

                    <LinearLayout
                        android:id="@+id/breakfastActions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <Button
                            android:id="@+id/addCustomDishBreakfast"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/action_button"
                            android:backgroundTint="@null"
                            android:text="@string/add_custom_dish"
                            android:textAllCaps="false"
                            app:backgroundTint="@null" />

                        <Button
                            android:id="@+id/libraryBreakfast"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/action_button"
                            android:backgroundTint="@null"
                            android:text="@string/library_dishes"
                            android:textAllCaps="false"
                            app:backgroundTint="@null" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="vertical">

                    <Button
                        android:id="@+id/lunchButton"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/button_background"
                        android:backgroundTint="@null"
                        android:drawableEnd="@drawable/strelka"
                        android:gravity="center_vertical|start"
                        android:paddingStart="14dp"
                        android:paddingEnd="12dp"
                        android:text="@string/meal_lunch"
                        android:textAllCaps="false"
                        android:textColor="#258B4E"
                        android:textSize="24sp"
                        app:backgroundTint="@null" />

                    <LinearLayout
                        android:id="@+id/lunchActions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <Button
                            android:id="@+id/addCustomDishLunch"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/action_button"
                            android:backgroundTint="@null"
                            android:text="@string/add_custom_dish"
                            android:textAllCaps="false"
                            app:backgroundTint="@null" />

                        <Button
                            android:id="@+id/libraryLunch"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/action_button"
                            android:backgroundTint="@null"
                            android:text="@string/library_dishes"
                            android:textAllCaps="false"
                            app:backgroundTint="@null" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="vertical">

                    <Button
                        android:id="@+id/dinnerButton"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/button_background"
                        android:backgroundTint="@null"
                        android:drawableEnd="@drawable/strelka"
                        android:gravity="center_vertical|start"
                        android:paddingStart="14dp"
                        android:paddingEnd="12dp"
                        android:text="@string/meal_dinner"
                        android:textAllCaps="false"
                        android:textColor="#258B4E"
                        android:textSize="24sp"
                        app:backgroundTint="@null" />

                    <LinearLayout
                        android:id="@+id/dinnerActions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <Button
                            android:id="@+id/addCustomDishDinner"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/action_button"
                            android:backgroundTint="@null"
                            android:text="@string/add_custom_dish"
                            android:textAllCaps="false"
                            app:backgroundTint="@null" />

                        <Button
                            android:id="@+id/libraryDinner"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/action_button"
                            android:backgroundTint="@null"
                            android:text="@string/library_dishes"
                            android:textAllCaps="false"
                            app:backgroundTint="@null" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/shoppingSuggestion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="#EEF7EC"
                    android:padding="12dp"
                    android:text="@string/suggestion_add_ingredients"
                    android:textColor="#2E6B2F"
                    android:textSize="13sp"
                    android:visibility="gone" />
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottomNavigation"
        android:layout_width="0dp"
        android:layout_height="69dp"
        android:background="@drawable/bottom_nav_background"
        android:orientation="horizontal"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Кнопка "Сегодня" -->
        <LinearLayout
            android:id="@+id/todayButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/nav_button_selector"
            android:padding="4dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/calendar"
                android:scaleType="centerInside" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/nav_today"
                android:textColor="#1F2A24"
                android:textSize="12sp"
                android:textAllCaps="false" />
        </LinearLayout>

        <!-- Кнопка "Список покупок" -->
        <LinearLayout
            android:id="@+id/shoppingListButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/nav_button_selector"
            android:padding="4dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/pokupki"
                android:scaleType="centerInside" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/nav_shopping"
                android:textColor="#1F2A24"
                android:textSize="12sp"
                android:textAllCaps="false" />
        </LinearLayout>

        <!-- Кнопка "Семья" -->
        <LinearLayout
            android:id="@+id/familyButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/nav_button_selector"
            android:padding="4dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/family"
                android:scaleType="centerInside" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/nav_family"
                android:textColor="#1F2A24"
                android:textSize="12sp"
                android:textAllCaps="false" />
        </LinearLayout>

        <!-- Кнопка "Библиотека" -->
        <LinearLayout
            android:id="@+id/libraryButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/nav_button_selector"
            android:padding="4dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/biblio"
                android:scaleType="centerInside" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/nav_library"
                android:textColor="#1F2A24"
                android:textSize="12sp"
                android:textAllCaps="false" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>