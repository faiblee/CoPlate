<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EFEFEF">

    <LinearLayout
        android:id="@+id/screenContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="16dp"
        android:background="#FFFFFF"
        android:elevation="4dp"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/week_days"
                android:textColor="#222222"
                android:textSize="26sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/settingsButton"
                android:layout_width="84dp"
                android:layout_height="84dp"
                android:background="@drawable/day_week_circle_selector"
                android:gravity="center"
                android:padding="10dp"
                android:text="@string/settings"
                android:textAllCaps="false"
                android:textSize="12sp" />
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:scrollbars="none">

            <RadioGroup
                android:id="@+id/dayGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/monday"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/day_week_circle_selector"
                    android:button="@null"
                    android:checked="true"
                    android:gravity="center"
                    android:text="Пн"
                    android:textColor="@color/day_week_text_selector"
                    android:textStyle="bold" />

                <RadioButton
                    android:id="@+id/tuesday"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/day_week_circle_selector"
                    android:button="@null"
                    android:gravity="center"
                    android:text="Вт"
                    android:textColor="@color/day_week_text_selector"
                    android:textStyle="bold" />

                <RadioButton
                    android:id="@+id/wednesday"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/day_week_circle_selector"
                    android:button="@null"
                    android:gravity="center"
                    android:text="Ср"
                    android:textColor="@color/day_week_text_selector"
                    android:textStyle="bold" />

                <RadioButton
                    android:id="@+id/thursday"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/day_week_circle_selector"
                    android:button="@null"
                    android:gravity="center"
                    android:text="Чт"
                    android:textColor="@color/day_week_text_selector"
                    android:textStyle="bold" />

                <RadioButton
                    android:id="@+id/friday"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/day_week_circle_selector"
                    android:button="@null"
                    android:gravity="center"
                    android:text="Пт"
                    android:textColor="@color/day_week_text_selector"
                    android:textStyle="bold" />

                <RadioButton
                    android:id="@+id/saturday"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/day_week_circle_selector"
                    android:button="@null"
                    android:gravity="center"
                    android:text="Сб"
                    android:textColor="@color/day_week_text_selector"
                    android:textStyle="bold" />

                <RadioButton
                    android:id="@+id/sunday"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/day_week_circle_selector"
                    android:button="@null"
                    android:gravity="center"
                    android:text="Вс"
                    android:textColor="@color/day_week_text_selector"
                    android:textStyle="bold" />
            </RadioGroup>
        </HorizontalScrollView>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="18dp"
            android:layout_weight="1"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/selectedDayLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/today_menu"
                    android:textColor="#666666"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/break_lunch_dinner_background"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <Button
                        android:id="@+id/breakfastButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/button_background"
                        android:textAllCaps="false" />

                    <LinearLayout
                        android:id="@+id/breakfastActions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical">

                        <Button
                            android:id="@+id/addCustomDishBreakfast"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/action_button"
                            android:text="@string/add_custom_dish"
                            android:textAllCaps="false" />

                        <Button
                            android:id="@+id/libraryBreakfast"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/action_button"
                            android:text="@string/library_dishes"
                            android:textAllCaps="false" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/break_lunch_dinner_background"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <Button
                        android:id="@+id/lunchButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/button_background"
                        android:textAllCaps="false" />

                    <LinearLayout
                        android:id="@+id/lunchActions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <Button
                            android:id="@+id/addCustomDishLunch"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/action_button"
                            android:text="@string/add_custom_dish"
                            android:textAllCaps="false" />

                        <Button
                            android:id="@+id/libraryLunch"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/action_button"
                            android:text="@string/library_dishes"
                            android:textAllCaps="false" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/break_lunch_dinner_background"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <Button
                        android:id="@+id/dinnerButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/button_background"
                        android:textAllCaps="false" />

                    <LinearLayout
                        android:id="@+id/dinnerActions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <Button
                            android:id="@+id/addCustomDishDinner"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/action_button"
                            android:text="@string/add_custom_dish"
                            android:textAllCaps="false" />

                        <Button
                            android:id="@+id/libraryDinner"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/action_button"
                            android:text="@string/library_dishes"
                            android:textAllCaps="false" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/shoppingSuggestion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="#EEF7EC"
                    android:padding="12dp"
                    android:text="@string/suggestion_add_ingredients"
                    android:textColor="#2E6B2F"
                    android:textSize="13sp"
                    android:visibility="gone" />
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottomNavigation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:background="#FFFFFF"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <Button
            android:id="@+id/todayButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bottom_button_selector"
            android:text="@string/nav_today"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/shoppingListButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bottom_button_selector"
            android:text="@string/nav_shopping"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/familyButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bottom_button_selector"
            android:text="@string/nav_family"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/libraryButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bottom_button_selector"
            android:text="@string/nav_library"
            android:textAllCaps="false" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>