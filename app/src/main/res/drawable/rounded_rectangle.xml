<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Цвет фона -->
    <solid android:color="#FFFFFF" />

    <!-- Скруглённые углы -->
    <corners android:radius="12dp" />

    <!-- Обводка (опционально) -->
    <stroke
        android:width="1dp"
        android:color="#258B4E" />

    <!-- Внутренние отступы (опционально) -->
    <padding
        android:left="8dp"
        android:top="8dp"
        android:right="8dp"
        android:bottom="8dp" />

</shape>